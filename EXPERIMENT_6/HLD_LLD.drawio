        <mxCell id="c4SiLya5yYz-4mM6RkZj-1" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;h1 data-start=&quot;480&quot; data-end=&quot;497&quot;&gt;Experiment 06&lt;/h1&gt;&#xa;&lt;h1 data-start=&quot;498&quot; data-end=&quot;543&quot;&gt;Design a Scalable YouTube-Like OTT Platform&lt;/h1&gt;&#xa;&lt;h3 data-start=&quot;545&quot; data-end=&quot;561&quot;&gt;Target Skill&lt;/h3&gt;&#xa;&lt;p data-start=&quot;562&quot; data-end=&quot;652&quot;&gt;Video Streaming using &lt;strong data-start=&quot;584&quot; data-end=&quot;652&quot;&gt;Manifest File + HLS/DASH + Interaction System (Likes &amp;amp; Comments)&lt;/strong&gt;&lt;/p&gt;" vertex="1">
