        <mxCell id="c4SiLya5yYz-4mM6RkZj-12" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;h2 data-start=&quot;2426&quot; data-end=&quot;2438&quot;&gt;&lt;br&gt;&lt;/h2&gt;&lt;h3 data-start=&quot;2440&quot; data-end=&quot;2452&quot;&gt;&lt;/h3&gt;&lt;h2 data-start=&quot;2426&quot; data-end=&quot;2438&quot;&gt;&lt;u&gt;1) User APIs:&lt;/u&gt;&lt;/h2&gt;&lt;h3 data-start=&quot;2440&quot; data-end=&quot;2452&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/h3&gt;&lt;h3 data-start=&quot;2440&quot; data-end=&quot;2452&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Register:&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;POST /user/register&lt;/span&gt;&lt;/h3&gt;&lt;pre class=&quot;overflow-visible! px-0!&quot; data-start=&quot;2454&quot; data-end=&quot;2481&quot;&gt;&lt;div class=&quot;relative w-full my-4&quot;&gt;&lt;div class=&quot;&quot;&gt;&lt;div class=&quot;relative&quot;&gt;&lt;div class=&quot;&quot;&gt;&lt;div class=&quot;&quot;&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/pre&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;h3 data-start=&quot;2488&quot; data-end=&quot;2497&quot;&gt;&lt;font size=&quot;3&quot;&gt;Login:&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;POST /user/login&lt;/span&gt;&lt;/h3&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;h2 data-start=&quot;2530&quot; data-end=&quot;2543&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;u&gt;2) Video APIs:&lt;/u&gt;&lt;/font&gt;&lt;/h2&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;h3 data-start=&quot;2545&quot; data-end=&quot;2561&quot;&gt;&lt;font size=&quot;3&quot;&gt;Upload Video:&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;POST /video/upload&lt;/span&gt;&lt;/h3&gt;&lt;br&gt;&lt;h3 data-start=&quot;2701&quot; data-end=&quot;2715&quot;&gt;&lt;font size=&quot;3&quot;&gt;Play Video:&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;GET /play/{video_id}&lt;/span&gt;&lt;/h3&gt;&lt;pre class=&quot;overflow-visible! px-0!&quot; data-start=&quot;2717&quot; data-end=&quot;2745&quot;&gt;&lt;div class=&quot;relative w-full my-4&quot;&gt;&lt;div class=&quot;&quot;&gt;&lt;div class=&quot;relative&quot;&gt;&lt;div class=&quot;&quot;&gt;&lt;div class=&quot;&quot;&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/pre&gt;&lt;p data-start=&quot;2747&quot; data-end=&quot;2754&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;h3 data-start=&quot;2788&quot; data-end=&quot;2804&quot;&gt;&lt;font size=&quot;3&quot;&gt;Search Video:&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;GET /search?q={video_name}&lt;/span&gt;&lt;/h3&gt;&lt;pre class=&quot;overflow-visible! px-0!&quot; data-start=&quot;2806&quot; data-end=&quot;2840&quot;&gt;&lt;div class=&quot;relative w-full my-4&quot;&gt;&lt;div class=&quot;&quot;&gt;&lt;div class=&quot;relative&quot;&gt;&lt;div class=&quot;&quot;&gt;&lt;div class=&quot;&quot;&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/pre&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;p data-start=&quot;2842&quot; data-end=&quot;2845&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;u&gt;&lt;b&gt;3) Likes API:&lt;/b&gt;&lt;/u&gt;&lt;/font&gt;&lt;/p&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;h3 data-start=&quot;2891&quot; data-end=&quot;2905&quot;&gt;&lt;font size=&quot;3&quot;&gt;Like Video:&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;POST /video/{video_id}/like&lt;/span&gt;&lt;/h3&gt;&lt;pre class=&quot;overflow-visible! px-0!&quot; data-start=&quot;2907&quot; data-end=&quot;2942&quot;&gt;&lt;div class=&quot;relative w-full my-4&quot;&gt;&lt;div class=&quot;&quot;&gt;&lt;div class=&quot;relative&quot;&gt;&lt;div class=&quot;&quot;&gt;&lt;div class=&quot;&quot;&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/pre&gt;&lt;p data-start=&quot;2944&quot; data-end=&quot;2949&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;h3 data-start=&quot;2982&quot; data-end=&quot;2998&quot;&gt;&lt;font size=&quot;3&quot;&gt;Unlike Video:&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;DELETE /video/{video_id}/like&lt;/span&gt;&lt;/h3&gt;&lt;div&gt;&lt;span style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;h3 data-start=&quot;3044&quot; data-end=&quot;3063&quot;&gt;&lt;font size=&quot;3&quot;&gt;Get Likes Count:&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-size: medium; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;GET /video/{video_id}/likes&lt;/span&gt;&lt;/h3&gt;&lt;pre class=&quot;overflow-visible! px-0!&quot; data-start=&quot;3065&quot; data-end=&quot;3100&quot;&gt;&lt;div class=&quot;relative w-full my-4&quot;&gt;&lt;div class=&quot;&quot;&gt;&lt;div class=&quot;relative&quot;&gt;&lt;div class=&quot;&quot;&gt;&lt;div class=&quot;&quot;&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/pre&gt;&lt;h1 data-start=&quot;3107&quot; data-end=&quot;3124&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;b